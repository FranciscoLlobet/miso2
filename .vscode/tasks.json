{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        { 
            "label": "Zig Build",
            "type": "shell",
            "command": "uv run python -mziglang build",
            "problemMatcher": [
                "$zig"
            ],
            "group" : {
                "kind" : "build",
                "isDefault": true
            }
            "isBackground": true
        },
        {
            "label": "uv sync",
            "type" : "shell",
            "command": "uv sync",
            "group": {
                "kind" :"none",
                "isDefault": 
                
            }  
        }
    ]
}